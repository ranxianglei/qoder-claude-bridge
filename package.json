{
  "name": "qoder-claude-bridge",
  "version": "0.1.0",
  "description": "Bridge Qoder ACP protocol into Claude Code via QueryDeps.callModel injection",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --noEmit && node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
